{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pratibmb",
  "version": "0.2.0",
  "identifier": "app.pratibmb",
  "build": {
    "frontendDist": "../ui",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "Pratibmb",
        "width": 900,
        "height": 700,
        "minWidth": 700,
        "minHeight": 500,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' http://127.0.0.1:11435"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.png", "icons/icon.ico"],
    "category": "Utility",
    "shortDescription": "Chat with your 10-years-younger self",
    "longDescription": "Pratibmb ingests your personal history and lets you chat with past-you. 100% local, no cloud, no telemetry."
  }
}
